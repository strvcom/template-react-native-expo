{
  "name": "template-react-native-expo",
  "version": "0.0.0",
  "main": "expo-router/entry",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "husky install",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean:folders": "rm -rf ios && rm -rf android",
    "format:check": "prettier --check '**/*.{ts,tsx,md,json}'",
    "format:fix": "prettier --write '**/*.{ts,tsx,md,json}'",
    "lint": "eslint --cache --concurrency=auto",
    "spellcheck": "cspell --no-progress --gitignore **/*.{js,ts,tsx,json,md}",
    "test": "pnpm jest",
    "lint:fix": "eslint --cache --concurrency=auto --fix",
    "type:check": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@dev-plugins/react-native-mmkv": "^0.4.0",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "^54.0.22",
    "expo-asset": "~12.0.9",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.17",
    "expo-font": "~14.0.9",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "expo-updates": "~29.0.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "~3.3.3",
    "react-native-reanimated": "~4.1.3",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@release-it/conventional-changelog": "^8.0.2",
    "@strv/eslint-config-react-native": "^4.1.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "@types/semver": "^7.7.1",
    "cspell": "^9.2.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.13",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "release-it": "^17.11.0",
    "release-it-webhook": "^0.0.5",
    "typescript": "~5.9.3"
  }
}
