{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "incremental": true,
    "allowJs": true,
    "typeRoots": ["./src/types", "node_modules/@types"],
    "types": ["jest", "react", "semver"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    }
  },
  "include": ["**/*.js", "**/*.mjs", "**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
